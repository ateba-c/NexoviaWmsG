# Django
DJANGO_SECRET_KEY=change-me
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_DEBUG=True
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database
DATABASE_URL=postgresql://nexoflow:dev_password@localhost:5432/nexoflow
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# PostgreSQL discrete settings for local compose
POSTGRES_DB=nexoflow
POSTGRES_USER=nexoflow
POSTGRES_PASSWORD=dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CHANNEL_URL=redis://localhost:6379/1

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=nexoflow-tenant-data
AWS_S3_REGION=ca-central-1

# Integrations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_SYSTEM_PROMPT=You are the NexoFlow warehouse copilot. Provide concise warehouse operations guidance.
ANTHROPIC_API_KEY=
EASYPOST_API_KEY=
SENTRY_DSN=

# Email
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@nexoflow.local

# JWT
JWT_SIGNING_KEY=change-me
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1
